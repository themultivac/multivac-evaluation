# The Multivac - API Configuration
# Copy this file to .env and add your actual keys

# OpenRouter API (https://openrouter.ai/)
# Used for: Claude, GPT, Gemini, DeepSeek, and most models
OPENROUTER_API_KEY=your_openrouter_key_here

# xAI API (https://x.ai/)
# Used for: Grok models (optional - most models work with just OpenRouter)
XAI_API_KEY=your_xai_key_here

# Note: You need at least OPENROUTER_API_KEY to run evaluations
# XAI_API_KEY is optional and only needed if you want to use Grok models directly
